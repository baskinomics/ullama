{
    "$schema": "https://opencode.ai/config.json",
    // Agents
    "default_agent": "plan",
    // Permissions
    "permission": {
        "webfetch": "allow",
        "question": "allow",
    },
    // Providers
    "enabled_providers": [
        "llama.cpp"
    ],
    "provider": {
        "llama.cpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama-server",
            "options": {
                "baseURL": "http://jupiter:8001/v1",
            },
            // Models
